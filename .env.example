TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# OpenRouter (облако)
OPEN_API_KEY=your_openrouter_api_key
OPEN_BASE_URL=https://openrouter.ai/api/v1
MODEL=nvidia/nemotron-3-nano-30b-a3b:free
VISION_MODEL=google/gemini-2.0-flash-lite-preview-02-05:free
AUDIO_MODEL=openai/gpt-audio-mini

# Ollama (локально) — те же имена переменных
# OPEN_BASE_URL=http://localhost:11434/v1
# MODEL=llama3.2:1b
# VISION_MODEL=llava:7b
# AUDIO_MODEL=llama3.2:1b
# OPEN_API_KEY не нужен

# Альтернативное имя ключа для OpenRouter: OPENROUTER_API_KEY
# FFMPEG_PATH=C:\Users\you\scoop\apps\ffmpeg\current\bin\ffmpeg.exe
DIALOG_MAX_PAIRS=20
EMBEDDING_MODEL=text-embedding-3-small
# RAG_TOP_K=5

# Tavily (веб-поиск)
TAVILY_API_KEY=your_tavily_api_key
# WEB_SEARCH_MAX_RESULTS=5

# SYSTEM_PROMPT_FILE=system.txt
# IMAGE_PROMPT_FILE=prompts/image.txt
# AUDIO_PROMPT_FILE=prompts/audio.txt

# LangSmith (трейсинг агентного цикла)
LANGSMITH_ENABLED=false
# LANGSMITH_API_KEY=your_langsmith_api_key
# LANGSMITH_PROJECT=expresscourse
