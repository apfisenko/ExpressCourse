TELEGRAM_BOT_TOKEN=your_telegram_bot_token

OPEN_API_KEY=your_openrouter_api_key
# Альтернативное имя (Railway / OpenRouter): OPENROUTER_API_KEY
OPEN_BASE_URL=https://openrouter.ai/api/v1
MODEL=nvidia/nemotron-3-nano-30b-a3b:free
# Альтернативное имя: OPENROUTER_MODEL или LLM_MODEL
DIALOG_MAX_PAIRS=20

# Необязательно: путь к файлу с системным промптом (по умолчанию system.txt)
# SYSTEM_PROMPT_FILE=system.txt
